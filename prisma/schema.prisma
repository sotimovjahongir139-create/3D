generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  login     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
}

enum Role {
  admin
  dept_3d
  dept_mold
  dept_sales
}

model ProductionModel {
  id        String   @id @default(cuid())
  name      String
  category  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  items     ProductionItem[]
}

// Uploaded image bytes live in Postgres, not the local filesystem. Production
// runs behind multiple app instances/processes with separate local disks - a
// file written to one instance's disk is invisible to a request served by
// another, which made every "successful" upload 404 unpredictably. Every
// instance already shares this same database, so storing bytes here is the
// only storage that's actually consistent regardless of server topology.
model UploadedImage {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())
}

model ProductionItem {
  id           String    @id @default(cuid())
  modelId      String
  model        ProductionModel @relation(fields: [modelId], references: [id])
  currentStage Stage
  stageStart   DateTime?
  deadline     DateTime?
  sampleSent   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  logs         StageLog[]
  proposals    Proposal[]
}

enum Stage {
  stage_umarxon
  stage_3d
  stage_mold
  stage_tayorlash
  stage_sales
}

model StageLog {
  id               String         @id @default(cuid())
  productionItemId String
  productionItem   ProductionItem @relation(fields: [productionItemId], references: [id])
  stage            Stage
  startDate        DateTime
  endDate          DateTime
  finishedById     String
}

model Proposal {
  id               String         @id @default(cuid())
  productionItemId String
  productionItem   ProductionItem @relation(fields: [productionItemId], references: [id])
  clientName       String
  date             DateTime       @default(now())
  status           ProposalStatus @default(sent)
}

enum ProposalStatus {
  sent
  won
  lost
}
